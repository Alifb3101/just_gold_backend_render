NODE_ENV=production
PORT=5000

# Frontend Configuration
FRONTEND_URL=https://your-frontend-domain.com
FRONTEND_URL_ALT=https://www.your-frontend-domain.com

# JWT Configuration
JWT_SECRET=your_super_secret_key_here_at_least_32_characters
JWT_EXPIRES_IN=7d

# Guest Cart Configuration
GUEST_TOKEN_HEADER_NAME=X-Guest-Token
GUEST_CART_COOKIE_NAME=guest_token
CART_DEBUG=false

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
MEDIA_BASE_URL=https://res.cloudinary.com/your_cloud_name/image/upload

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Redis Configuration (Optional)
REDIS_URL=redis://127.0.0.1:6379

# Checkout Configuration
CHECKOUT_TAX_PERCENT=5
CHECKOUT_SHIPPING_FEE=15
CHECKOUT_FREE_SHIPPING_THRESHOLD=200

# Email Configuration (Brevo SMTP)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=a96364001@smtp-brevo.com
SMTP_PAS=your_brevo_smtp_password_here
MAIL_FROM=order@justgoldcosmetics.com 
ADMIN_EMAIL=justgoldcosmetic@gmail.com

# Optional Email Branding/Content
EMAIL_BRAND_LOGO_URL=https://i.postimg.cc/PqTfCmLW/Whats-App-Image-2026-02-03-at-12-22-57-PM-Nero-AI-Background-Remover-transparent.png
EMAIL_NEWSLETTER_IMAGE_URL=https://i.postimg.cc/PqTfCmLW/Whats-App-Image-2026-02-03-at-12-22-57-PM-Nero-AI-Background-Remover-transparent.png
EMAIL_NEWSLETTER_HEADING=Welcome to the Just Gold Beauty Circle
EMAIL_NEWSLETTER_INTRO=Thanks for subscribing to the Just Gold Cosmetics newsletter.
EMAIL_NEWSLETTER_DETAILS=You will be first to know about limited drops, exclusive offers, and beauty tips curated by our team.
EMAIL_NEWSLETTER_CTA_TEXT=Explore New Arrivals
EMAIL_NEWSLETTER_SUPPORT=Need help picking products? Reach us through our support page.

